rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helpers ─────────────────────────────────────────────────────────────
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user has an admin role via Custom Claims
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Check if the user is accessing their own data
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ─── Catalog (Public contents) ───────────────────────────────────────────
    
    // Films: Everyone can read, only admin can manage
    match /films/{filmId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Series: Everyone can read, only admin can manage
    match /series/{seriesId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /seasons/{seasonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();

        match /episodes/{episodeId} {
          allow read: if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // ─── User Personal Data (Sync features) ──────────────────────────────────
    
    match /users/{userId} {
      // User can manage their profile, admin can too
      allow read, write: if isOwner(userId) || isAdmin();

      // Cloud Favorites Synchronization
      match /favorites/{favId} {
        allow read, write: if isOwner(userId);
      }

      // Multi-profile management
      match /profiles/{profileId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ─── Search analytics / metadata (Optional future use) ───────────────────
    match /search_metadata/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Premium access / video entitlement ──────────────────────────────────
    match /access_codes/{codeId} {
      allow read, write: if isAdmin();
    }

    match /user_entitlements/{entitlementId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    match /watch_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    match /content_access_rules/{ruleId} {
      allow read, write: if isAdmin();
    }
  }
}
