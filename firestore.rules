rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /films/{filmId} {
      allow read: if isSignedIn();
    }

    match /series/{seriesId} {
      allow read: if isSignedIn();

      match /seasons/{seasonId} {
        allow read: if isSignedIn();

        match /episodes/{episodeId} {
          allow read: if isSignedIn();
        }
      }
    }
  }
}
