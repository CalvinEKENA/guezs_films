rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helpers ─────────────────────────────────────────────────────────────
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user has an admin role via Custom Claims
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Check if the user is accessing their own data
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Fields that a client may manage on its own public profile document.
    // Billing, premium and role fields remain server/admin controlled.
    function hasOnlyClientProfileFields() {
      return request.resource.data.keys().hasOnly([
        'displayName',
        'photoUrl',
        'createdAt',
        'updatedAt'
      ]);
    }

    function changesOnlyClientProfileFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName',
        'photoUrl',
        'updatedAt'
      ]);
    }

    // ─── Catalog (Public contents) ───────────────────────────────────────────
    
    // Films: Everyone can read, only admin can manage
    match /films/{filmId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Series: Everyone can read, only admin can manage
    match /series/{seriesId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /seasons/{seasonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();

        match /episodes/{episodeId} {
          allow read: if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // ─── User Personal Data (Sync features) ──────────────────────────────────
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() ||
        (isOwner(userId) && hasOnlyClientProfileFields());
      allow update: if isAdmin() ||
        (isOwner(userId) && changesOnlyClientProfileFields());
      allow delete: if isOwner(userId) || isAdmin();

      // Cloud Favorites Synchronization
      match /favorites/{favId} {
        allow read, write: if isOwner(userId);
      }

      // Multi-profile management
      match /profiles/{profileId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ─── Search analytics / metadata (Optional future use) ───────────────────
    match /search_metadata/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Premium access / video entitlement ──────────────────────────────────
    // Sensitive premium-access documents are written by Cloud Functions/Admin SDK.
    // Client SDKs must not create codes, entitlements, sessions or access rules.
    match /access_codes/{codeId} {
      allow read, write: if false;
    }

    match /user_entitlements/{entitlementId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /watch_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /content_access_rules/{ruleId} {
      allow read, write: if false;
    }
  }
}
